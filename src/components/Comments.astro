---
// src/components/Comments.astro
---
<div class="comments-container" style="margin-top: 50px; padding: 30px; border-top: 2px solid #e2e8f0;">
  <div style="background: #f1f5f9; padding: 25px; border-radius: 12px; margin-bottom: 30px; border-left: 5px solid #10b981;">
    <h3 style="margin: 0; color: #0f172a;">💬 Deixe sua dúvida ou sugestão!</h3>
    <p style="margin: 5px 0 0 0; color: #475569;">Eu respondo pessoalmente para te ajudar na sua viagem.</p>
  </div>

  <!-- Onde o comentário vai aparecer -->
  <div 
    id="cusdis_thread"
    data-host="https://cusdis.com"
    data-app-id="b8307b5d-3893-46a8-9f13-cff3ecedc9df"
    data-page-id={Astro.url.pathname}
    data-page-url={Astro.url.href}
    data-page-title={Astro.url.pathname}
    data-theme="light"
  ></div>

  <script is:inline>
    // 1. TRADUÇÃO COMPLETA PARA PORTUGUÊS
    window.CUSDIS_LOCALE = {
      "powered_by": "Comentários por",
      "post": "Enviar Comentário",
      "loading": "Carregando...",
      "email": "E-mail (opcional)",
      "nickname": "Seu Nome",
      "reply_placeholder": "Escreva aqui sua dúvida...",
      "reply_btn": "Responder",
      "sending": "Enviando...",
      "mod_badge": "Especialista",
      "content_is_required": "Escreva algo antes de enviar",
      "nickname_is_required": "Diga-nos o seu nome",
      "comment_has_been_sent": "Mensagem enviada! Aparecerá aqui após aprovação."
    };

    function runCusdis() {
      // Limpa qualquer erro anterior e força o carregamento
      if (window.CUSDIS) {
        window.CUSDIS.initial();
      } else {
        // Se o script ainda não carregou, ele cria um novo
        const script = document.createElement('script');
        script.src = 'https://cusdis.com/js/cusdis.es.js';
        script.async = true;
        script.defer = true;
        document.body.appendChild(script);
      }
    }

    // ISSO RESOLVE O PROBLEMA DO F5 NO ASTRO
    // Executa no carregamento inicial
    window.addEventListener('load', runCusdis);
    // Executa toda vez que você clica no menu e troca de página
    document.addEventListener('astro:page-load', runCusdis);
    document.addEventListener('astro:after-swap', runCusdis);
  </script>
</div>